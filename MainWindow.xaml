<Window x:Class="CyberSecurityBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cyber Security Awareness Bot"
        Height="720"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#111827">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT PANEL -->
        <Border Background="#0F172A"
                Padding="20">

            <StackPanel>

                <Image Source="pack://application:,,,/Assets/ascii_logo.png"
                       Width="140"
                       Height="140"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

                <TextBlock Text="CYBER SECURITY"
                           Foreground="Cyan"
                           FontSize="28"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="AWARENESS BOT"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30"/>

            </StackPanel>
        </Border>

        <!-- RIGHT SIDE -->
        <Grid Grid.Column="1"
              Margin="15">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- TITLE -->
            <Border Background="#1E293B"
                    CornerRadius="10"
                    Padding="20"
                    Margin="0,0,0,15">

                <TextBlock Text="Cyber Security Chat Assistant"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="White"/>
            </Border>

            <!-- CHAT -->
            <Border Grid.Row="1"
                    Background="#1F2937"
                    CornerRadius="10"
                    Padding="15">

                <ScrollViewer VerticalScrollBarVisibility="Auto">

                    <TextBox x:Name="ChatArea"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             FontSize="16"
                             FontFamily="Consolas"
                             Background="#1F2937"
                             Foreground="White"
                             BorderThickness="0"
                             AcceptsReturn="True"/>

                </ScrollViewer>
            </Border>

            <!-- BUTTONS + INPUT -->
            <StackPanel Grid.Row="2"
                        Margin="0,15,0,0">

                <WrapPanel HorizontalAlignment="Center"
                           Margin="0,0,0,15">

                    <Button Content="Password Safety"
                            Width="180"
                            Height="50"
                            Margin="5"
                            FontSize="16"
                            FontWeight="Bold"
                            Background="Cyan"
                            Foreground="Black"
                            Click="PasswordButton_Click"/>

                    <Button Content="Phishing Tips"
                            Width="180"
                            Height="50"
                            Margin="5"
                            FontSize="16"
                            FontWeight="Bold"
                            Background="LightGreen"
                            Foreground="Black"
                            Click="PhishingButton_Click"/>

                    <Button Content="Privacy Protection"
                            Width="180"
                            Height="50"
                            Margin="5"
                            FontSize="16"
                            FontWeight="Bold"
                            Background="Orange"
                            Foreground="Black"
                            Click="PrivacyButton_Click"/>

                    <Button Content="Online Scams"
                            Width="180"
                            Height="50"
                            Margin="5"
                            FontSize="16"
                            FontWeight="Bold"
                            Background="Pink"
                            Foreground="Black"
                            Click="ScamButton_Click"/>
                    <Button Content="Add Task"
                            Width="180"
                            Height="50"
                            Margin="5"
                            FontSize="16"
                            FontWeight="Bold"
                            Background="red"
                            Foreground="Black"
                            Click="AddTaskButton_Click"/>

                    <Button Content="View Tasks"
                            Width="180"
                            Height="50"
                            Margin="5"
                            FontSize="16"
                            FontWeight="Bold"
                            Background="purple"
                            Foreground="Black"
                            Click="ViewTasksButton_Click"/>

                    <Button Content="Delete Task"
                            Width="180"
                            Height="50"
                            Margin="5"
                            FontSize="16"
                            FontWeight="Bold"
                            Background="yellow"
                            Foreground="Black"
                            Click="DeleteTaskButton_Click"/>

                    <Button Content="Complete Task"
                            Width="180"
                            Height="50"
                            Margin="5"
                            FontSize="16"
                            FontWeight="Bold"
                            Background="green"
                            Foreground="Black"
                            Click="CompleteTaskButton_Click"/>

                    <Button Content="Activity Log"
                            Width="180"
                            Height="50"
                            Margin="5"
                            FontSize="16"
                            FontWeight="Bold"
                            Background="white"
                            Foreground="Black"
                            Click="ActivityLogButton_Click"/>
                    <Button Content="Start Quiz"
                            Width="180"
                            Height="50"
                            Margin="5"
                            FontSize="16"
                            FontWeight="Bold"
                            Background="gray"
                            Foreground="Black"
                            Click="StartQuizButton_Click"/>
                </WrapPanel>

                <!-- INPUT -->
                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="170"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="UserInput"
                             Height="50"
                             FontSize="16"
                             Padding="12"
                             Background="#374151"
                             Foreground="White"
                             BorderBrush="Cyan"
                             KeyDown="UserInput_KeyDown"/>

                    <Button Grid.Column="1"
                            Content="Send"
                            Margin="15,0,0,0"
                            FontSize="18"
                            FontWeight="Bold"
                            Background="Cyan"
                            Foreground="Black"
                            BorderThickness="0"
                            Click="SendButton_Click"/>

                </Grid>

            </StackPanel>

        </Grid>

    </Grid>
</Window>